{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/agentic-trading/shadow_trade.schema.json",
  "title": "Shadow Trade",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "shadow_id",
    "created_at",
    "symbol",
    "asset_type",
    "hypothetical_entry_price",
    "hypothetical_dollar_amount",
    "hypothetical_funding_source",
    "reason_not_traded",
    "expected_reward_risk",
    "confidence",
    "thesis_file",
    "status",
    "plan_version",
    "risk_policy_version",
    "autonomy_policy_version",
    "scoring_policy_version"
  ],
  "properties": {
    "shadow_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "symbol": { "type": "string", "pattern": "^[A-Z][A-Z0-9.\\-]{0,9}$" },
    "asset_type": { "type": "string", "enum": ["etf", "stock", "other"] },
    "hypothetical_entry_price": { "type": "number", "exclusiveMinimum": 0 },
    "hypothetical_dollar_amount": { "type": "number", "minimum": 0 },
    "hypothetical_funding_source": { "type": "string", "minLength": 1 },
    "reason_not_traded": { "type": "string", "minLength": 1 },
    "expected_reward_risk": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?:1$" },
    "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
    "thesis_file": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["open", "monitoring", "closed", "invalidated"] },
    "return_1d": { "type": ["number", "null"] },
    "return_5d": { "type": ["number", "null"] },
    "return_20d": { "type": ["number", "null"] },
    "return_60d": { "type": ["number", "null"] },
    "plan_version": { "type": "string", "minLength": 1 },
    "risk_policy_version": { "type": "string", "minLength": 1 },
    "autonomy_policy_version": { "type": "string", "minLength": 1 },
    "scoring_policy_version": { "type": "string", "minLength": 1 }
  }
}
