{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Automation Run Record",
  "type": "object",
  "additionalProperties": true,
  "required": ["run_id", "automation", "mode", "stage", "started_at", "completed_at", "status", "summary", "evidence_class"],
  "properties": {
    "run_id": {"type": "string", "minLength": 1},
    "automation": {"type": "string", "minLength": 1},
    "mode": {"const": "STAGED_AUTONOMY"},
    "stage": {"enum": ["OBSERVE", "PAPER", "HUMAN_APPROVED_LIVE", "ADAPTIVE_RESEARCH"]},
    "started_at": {"type": "string", "format": "date-time"},
    "completed_at": {"type": "string", "format": "date-time"},
    "duration_seconds": {"type": ["integer", "null"], "minimum": 0},
    "status": {"enum": ["succeeded", "no_action", "blocked", "failed", "abandoned"]},
    "summary": {"type": "string", "minLength": 1},
    "evidence_class": {"enum": ["repository_recorded", "broker_confirmed"]}
  }
}
