{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/agentic-trading/signal_score.schema.json",
  "title": "Signal Score",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "score_id",
    "candidate_id",
    "symbol",
    "scored_at",
    "scored_by",
    "model",
    "reasoning_effort",
    "momentum_score",
    "quality_score",
    "catalyst_score",
    "liquidity_score",
    "risk_score",
    "portfolio_fit_score",
    "total_score",
    "reward_risk_estimate",
    "confidence",
    "evidence_summary",
    "data_sources",
    "status",
    "plan_version",
    "risk_policy_version",
    "autonomy_policy_version",
    "scoring_policy_version"
  ],
  "properties": {
    "score_id": { "type": "string", "minLength": 1 },
    "candidate_id": { "type": "string", "minLength": 1 },
    "symbol": { "type": "string", "pattern": "^[A-Z][A-Z0-9.\\-]{0,9}$" },
    "scored_at": { "type": "string", "format": "date-time" },
    "scored_by": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "minLength": 1 },
    "reasoning_effort": { "type": "string", "enum": ["Low", "Medium", "High"] },
    "momentum_score": { "type": "integer", "minimum": 0, "maximum": 20 },
    "quality_score": { "type": "integer", "minimum": 0, "maximum": 15 },
    "catalyst_score": { "type": "integer", "minimum": 0, "maximum": 20 },
    "liquidity_score": { "type": "integer", "minimum": 0, "maximum": 15 },
    "risk_score": { "type": "integer", "minimum": 0, "maximum": 15 },
    "portfolio_fit_score": { "type": "integer", "minimum": 0, "maximum": 15 },
    "total_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "reward_risk_estimate": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?:1$" },
    "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
    "evidence_summary": { "type": "string", "minLength": 1 },
    "data_sources": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "scored",
        "promotion_eligible",
        "promoted",
        "rejected_policy",
        "rejected_liquidity",
        "rejected_thesis",
        "rejected_risk_reward",
        "rejected_stale_data",
        "rejected_duplicate",
        "rejected_user_required"
      ]
    },
    "plan_version": { "type": "string", "minLength": 1 },
    "risk_policy_version": { "type": "string", "minLength": 1 },
    "autonomy_policy_version": { "type": "string", "minLength": 1 },
    "scoring_policy_version": { "type": "string", "minLength": 1 }
  }
}
